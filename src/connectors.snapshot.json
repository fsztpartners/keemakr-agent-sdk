              "first_name": {
                "type": "string",
                "minLength": 1,
                "description": "The person first name."
              },
              "last_name": {
                "type": "string",
                "minLength": 1,
                "description": "The person last name."
              }
            },
            "required": [
              "domain",
              "first_name",
              "last_name"
